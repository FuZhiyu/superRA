#!/usr/bin/env bash
# PreToolUse hook: intercept bare git merge/rebase/cherry-pick commands
# Injects a reminder to use superRA:semantic-merge for research-aware integration.
# Does NOT block — the discipline system handles enforcement.

# Test vectors for regression
# - `git merge foo-agent/parallel/a` → emit `{}` (exempt: parallel branch)
# - `git merge --no-ff feat-agent/parallel/b` → emit `{}` (exempt: parallel branch with flag)
# - `git merge main` → emit STOP reminder (require semantic-merge)
# - `git merge --abort` → emit `{}` (skip: abort is not a new merge)

set -euo pipefail

# Read tool input from stdin
if [ -x /bin/cat ]; then
  input=$(/bin/cat)
elif [ -x /usr/bin/cat ]; then
  input=$(/usr/bin/cat)
else
  input=$(cat)
fi

if [ -x /usr/bin/grep ]; then
  GREP=/usr/bin/grep
elif [ -x /bin/grep ]; then
  GREP=/bin/grep
else
  GREP=grep
fi

# Fast path: grep raw input for merge keywords before any JSON parsing.
# This makes the no-match case (vast majority of Bash calls) nearly zero-cost.
if ! echo "$input" | "$GREP" -qE 'git (merge|rebase|cherry-pick)(\s|"|$)' 2>/dev/null; then
  printf '{}\n'
  exit 0
fi

# Extract the command properly via JSON parsing
command=$(echo "$input" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('tool_input', {}).get('command', ''))
" 2>/dev/null || echo "")

# Skip abort, continue, skip, quit — these are not new merges
if echo "$command" | "$GREP" -qE 'git (merge|rebase|cherry-pick) --(abort|continue|skip|quit)' 2>/dev/null; then
  printf '{}\n'
  exit 0
fi

# Exempt orchestrator-managed parallel-task merges.
# Branch-name convention from superRA:agent-orchestration §Parallelization
# and Worktree Isolation — <current-branch>-agent/parallel/<slug> branches are disjoint
# by construction and merge with plain git merge.
if echo "$command" | "$GREP" -qE 'git (merge|rebase|cherry-pick)(\s+--?\S+)*\s+\S+/parallel/' 2>/dev/null; then
  printf '{}\n'
  exit 0
fi

# Detect actual merge/rebase/cherry-pick commands
if echo "$command" | "$GREP" -qE '(^|\s)git (merge|rebase|cherry-pick)(\s|$)' 2>/dev/null; then
  context="<IMPORTANT>Bare git merge/rebase/cherry-pick detected. Invoke superRA:semantic-merge first to integrate intentionally rather than mechanically.</IMPORTANT>"

  # Platform-appropriate output format (matches session-start pattern)
  if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{"additional_context":"%s"}\n' "$context"
  elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","additionalContext":"%s"}}\n' "$context"
  else
    printf '{"additionalContext":"%s"}\n' "$context"
  fi
else
  printf '{}\n'
fi

exit 0
