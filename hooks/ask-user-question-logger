#!/usr/bin/env bash
# PostToolUse hook: fires after AskUserQuestion/request_user_input returns an answer.
# Offers a reminder to record important user decisions in PLAN.md.
# Does NOT block — the discipline system handles enforcement.

set -euo pipefail

# Read tool input from stdin
input=$(cat)

# Fast path: only fire on AskUserQuestion or Codex request_user_input. The matcher in hooks.json
# should already scope us, but we double-check here so this hook is
# cheap and safe even if registered loosely.
tool_name=$(echo "$input" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('tool_name', '') or d.get('tool', ''))
except Exception:
    print('')
" 2>/dev/null || echo "")

case "$tool_name" in
  AskUserQuestion|request_user_input|functions.request_user_input)
    ;;
  *)
    printf '{}\n'
    exit 0
    ;;
esac

context="<IMPORTANT>You just received an answer from the user. If it affects scope, methodology, task status, or later reproducibility, consider recording it in PLAN.md before relying on it. See superRA:handoff-doc §User Decisions Log for the suggested format.</IMPORTANT>"

# Platform-appropriate output format (matches merge-guard / session-start pattern)
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context":"%s"}\n' "$context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"%s"}}\n' "$context"
else
  printf '{"additionalContext":"%s"}\n' "$context"
fi

exit 0
