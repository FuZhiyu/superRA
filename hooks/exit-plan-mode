#!/usr/bin/env bash
# PostToolUse hook: fires after ExitPlanMode returns.
# Offers a reminder to write durable .plan/ task files when a plan-mode result
# will guide implementation or another session.
# Does NOT block — discipline system handles enforcement.

set -euo pipefail

input=$(cat)

tool_name=$(echo "$input" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('tool_name', '') or d.get('tool', ''))
except Exception:
    print('')
" 2>/dev/null || echo "")

if [ "$tool_name" != "ExitPlanMode" ]; then
  printf '{}\n'
  exit 0
fi

context="<IMPORTANT>You just exited plan mode. If this plan will guide implementation, review, or handoff to another agent/session, consider materializing it into a .plan/ task tree using superRA:superplan before relying on it. If task files already exist and reflect the current plan, this reminder is satisfied.</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{"additional_context":"%s"}\n' "$context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"%s"}}\n' "$context"
else
  printf '{"additionalContext":"%s"}\n' "$context"
fi

exit 0
